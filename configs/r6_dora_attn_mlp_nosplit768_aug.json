{
  "model_id": "HuggingFaceTB/SmolVLM-500M-Instruct",
  "device": "cuda",
  "run_name": "r6-dora-attn-mlp-nosplit768-aug",
  "output_dir": "runs/r6-dora-attn-mlp-nosplit768-aug",
  "batch_size": 2,
  "eval_batch_size": 4,
  "epochs": 8,
  "min_epochs": 3,
  "patience": 3,
  "min_delta": 0.001,
  "lr": 1.6e-4,
  "grad_accum": 16,
  "max_length": 896,
  "num_workers": 2,
  "image_dir": "data/images/train",
  "val_image_dir": "data/images/val",
  "train_csv": "data/train.csv",
  "val_csv": "data/val.csv",
  "seed": 44,
  "dry_run": false,
  "allow_val_label_training": false,
  "max_trainable_params": 5000000,
  "objective": "letter_ce",
  "target_format": "letter",
  "image_mode": "nosplit768",
  "include_metadata": true,
  "metadata_fields": ["subject", "grade", "topic"],
  "lecture_max_chars": 384,
  "prompt_variant": ["default", "question_first", "context_first", "answer_short", "answer_phrase"],
  "prompt_variant_eval": "question_first",
  "leading_space_choices": true,
  "warmup_ratio": 0.05,
  "weight_decay": 0.01,
  "gradient_checkpointing": true,
  "image_augmentation": {
    "rotate_degrees": 2,
    "brightness": 0.05,
    "contrast": 0.05,
    "saturation": 0.03,
    "crop_scale_min": 0.97,
    "crop_scale_max": 1.0,
    "horizontal_flip_prob": 0.0
  },
  "lora": {
    "r": 6,
    "lora_alpha": 18,
    "lora_dropout": 0.05,
    "use_dora": true,
    "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"]
  },
  "wandb": {"project": "pixels-to-predictions", "entity": null}
}
